load("@rules_go//go:def.bzl", "go_library")

filegroup(
    name = "mcp_files",
    srcs = glob(["*.pb.mcp.go"]),
    visibility = ["//visibility:public"],
)

go_library(
    name = "testdatamcp",
    srcs = [
        "edge_cases.pb.mcp.go",
        "test_service.pb.mcp.go",
    ],
    importpath = "github.com/redpanda-data/protoc-gen-go-mcp/pkg/testdata/gen/go/testdata/testdatamcp",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/runtime",
        "//pkg/testdata/gen/go/testdata",
        "@com_connectrpc_connect//:connect",
        "@com_github_mark3labs_mcp_go//mcp",
        "@com_github_mark3labs_mcp_go//server",
        "@org_golang_google_grpc//:grpc",
        "@org_golang_google_protobuf//encoding/protojson",
    ],
)
